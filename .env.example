# ── flood-website-crm — Environment Variables ────────────────────────────────
# Copy this file to .env.local for local development.
# For Vercel: set these in Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── CRM Spring Boot API (flood-service-crm) ──────────────────────────────────
# Server-side BFF uses JAVA_API_URL. In Docker full stack, route through Kong:
#   JAVA_API_URL=http://kong-gateway:8000/crm
# Vercel + Railway (no Kong): direct Spring URL below.
# LOCAL:   http://localhost:4002
# VERCEL:  https://flood-service-crm-production.up.railway.app
# NEXT_PUBLIC_JAVA_API_URL — optional; browser still prefers /api/* BFF. Set to
# ${PUBLIC_GATEWAY_HTTP}/crm in Docker (deploy/docker-compose) so any legacy
# client-side calls hit the gateway consistently.
JAVA_API_URL=https://flood-service-crm-production.up.railway.app

# ── Community Spring Boot API (flood-service-community) ─────────────────────
# REQUIRED on Vercel — CRM BFF routes that read community-only data
# (threaded comments + admin moderation, UAT survey responses) call this
# backend. If unset, falls back to JAVA_API_URL — which 404s for any path
# that only exists on flood-service-community (e.g. /admin/surveys/uat).
# LOCAL (split services): http://localhost:4001
# Docker + Kong:          http://kong-gateway:8000/community
# Vercel + Railway:       https://flood-service-community-production.up.railway.app
COMMUNITY_JAVA_API_URL=https://flood-service-community-production.up.railway.app

# ── Community website URL (flood-website-community) ───────────────────────────
# LOCAL:   http://localhost:3002
# VERCEL:  your Vercel deployment URL, e.g. https://flood-website-community.vercel.app
NEXT_PUBLIC_COMMUNITY_URL=https://flood-website-community.vercel.app

# ── AI Prediction Service (flood-ai-prediction) ───────────────────────────────
# LOCAL:   http://localhost:8000
# VERCEL:  https://flood-ai-prediction.up.railway.app
AI_API_URL=https://flood-ai-prediction-production.up.railway.app

# ── Upstash Redis (server-side caching) ──────────────────────────────────────
# Get from: console.upstash.com → your database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Google Maps ───────────────────────────────────────────────────────────────
# Restrict this key to your Vercel domain in Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ── FloodWatch IoT API (read-only public source of truth) ────────────────────
# FastAPI service in Pitas, Sabah. Public, no auth. Defaults to the staging
# server if unset, so a fresh checkout works without local env config.
# Override here or in Vercel.
FLOODWATCH_API_BASE=http://159.223.70.28/api/v1
# Default dataset for every /api/iot/* and /api/sse/iot-events request:
#   real   — production LoRa data (2 nodes, near-silent in dev)
#   sample — SIM-PITAS simulator (22 personality-driven nodes, demo-loud)
#   all    — both combined
FLOODWATCH_DATASET=real

# ── Edge-side JWT signature verification (Phase 2.B hardening) ───────────────
# Must match `JWT_SECRET` on the flood-service-crm Railway service exactly.
# When set, `middleware.ts` calls `jose.jwtVerify` on every protected request
# and rejects forged / tampered / wrong-algorithm tokens at the Edge before
# the page renders. When unset, the middleware falls back to payload-only
# validation (structure + exp + role) and the Java backend's signature
# check on every authenticated call remains the wall against forgery.
#
# Recommended: set this on Vercel (Production + Preview). Local dev can
# either set it (copy the Railway value) or leave it blank for the
# payload-only fallback path.
JWT_SECRET=
