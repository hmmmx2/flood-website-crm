# Copy this file to .env.local and fill in real values
# Never commit .env.local to git

# ── Java Spring Boot API ──────────────────────────────────────────────────────
# Server-side Next.js API routes call this URL.
# Local dev: http://localhost:4002   |   Docker: http://crm-api:4002
# Production: https://crm-api.yourdomain.com
JAVA_API_URL=http://localhost:4002

# Browser-side auth calls — public-facing URL in production
NEXT_PUBLIC_JAVA_API_URL=http://localhost:4002

# ── Neon PostgreSQL ───────────────────────────────────────────────────────────
# Serverless Postgres — shared between both Java backend services and
# Next.js BFF layer. Get from: console.neon.tech → your project → Connection string
# Always use the POOLED connection string (?sslmode=require&channel_binding=require)
DATABASE_URL=postgresql://neondb_owner:<password>@<host>/neondb?sslmode=require&channel_binding=require

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# HTTP-based Redis cache for Next.js API routes (edge-compatible).
# Get from: console.upstash.com → your database → REST API
UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-token>

# ── Google Maps ───────────────────────────────────────────────────────────────
# 1. Go to console.cloud.google.com → APIs & Services → Credentials
# 2. Create an API key → restrict to "Maps JavaScript API" only
# 3. Add HTTP referrer restrictions: localhost/*, yourdomain.com/*
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ── Community app URL (for cross-app navigation) ──────────────────────────────
NEXT_PUBLIC_COMMUNITY_URL=http://localhost:3002
