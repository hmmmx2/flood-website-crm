# ── flood-website-crm — Environment Variables ────────────────────────────────
# Copy this file to .env.local for local development.
# For Vercel: set these in Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── CRM Spring Boot API (flood-service-crm) ──────────────────────────────────
# Server-side BFF uses JAVA_API_URL. In Docker full stack, route through Kong:
#   JAVA_API_URL=http://kong-gateway:8000/crm
# Vercel + Railway (no Kong): direct Spring URL below.
# LOCAL:   http://localhost:4002
# VERCEL:  https://flood-service-crm-production.up.railway.app
# NEXT_PUBLIC_JAVA_API_URL — optional; browser still prefers /api/* BFF. Set to
# ${PUBLIC_GATEWAY_HTTP}/crm in Docker (deploy/docker-compose) so any legacy
# client-side calls hit the gateway consistently.
JAVA_API_URL=https://flood-service-crm-production.up.railway.app

# ── Community Spring Boot API (flood-service-community) ─────────────────────
# Used by CRM BFF routes for threaded comments + admin moderation (GET/PATCH
# /community/admin/comments). Defaults to JAVA_API_URL if unset.
# LOCAL (split services): http://localhost:4001
# Docker + Kong: http://kong-gateway:8000/community
COMMUNITY_JAVA_API_URL=

# ── Community website URL (flood-website-community) ───────────────────────────
# LOCAL:   http://localhost:3002
# VERCEL:  your Vercel deployment URL, e.g. https://flood-website-community.vercel.app
NEXT_PUBLIC_COMMUNITY_URL=https://flood-website-community.vercel.app

# ── AI Prediction Service (flood-ai-prediction) ───────────────────────────────
# LOCAL:   http://localhost:8000
# VERCEL:  https://flood-ai-prediction.up.railway.app
AI_API_URL=https://flood-ai-prediction-production.up.railway.app

# ── Upstash Redis (server-side caching) ──────────────────────────────────────
# Get from: console.upstash.com → your database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Google Maps ───────────────────────────────────────────────────────────────
# Restrict this key to your Vercel domain in Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
